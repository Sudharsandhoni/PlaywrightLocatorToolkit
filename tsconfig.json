{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "ignoreDeprecations": "5.0",
    "paths": {
      "playwright-locator-toolkit-shared": ["packages/shared/src/index.ts"],
      "playwright-locator-toolkit-parser": ["packages/locator-parser/src/index.ts"],
      "playwright-locator-toolkit-agent": ["packages/browser-agent/src/index.ts"],
      "playwright-locator-toolkit-engine": ["packages/engine/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
