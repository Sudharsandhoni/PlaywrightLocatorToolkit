# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build outputs ────────────────────────────────────────────────────────────
dist/
out/
*.vsix

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Test artefacts ───────────────────────────────────────────────────────────
tests/chrome-profile/
tests/testresults.json
# Keep demo/test HTML pages so they are visible on GitHub
!tests/*.html

# ─── Coverage ─────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json
# Keep .vscode/tasks.json if present (shared task config)
!.vscode/tasks.json

# ─── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Environment / secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Temporary files ──────────────────────────────────────────────────────────
*.tmp
*.temp
.cache/


# ─── Miscellaneous ───────────────────────────────────────────────────────────
.vscode/playwright-locator-profile