{
  "name": "playwright-locator-toolkit",
  "displayName": "Playwright Live Playground",
  "description": "Live Playwright Playground & Locator Analysis in VS Code",
  "version": "0.2.1",
  "publisher": "sudharsan-ezhumalai",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "categories": [
    "Testing",
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "playwright-locator-toolkit-container",
          "title": "Playwright Live Playground (Debug Assistant)",
          "icon": "$(eye)"
        }
      ]
    },
    "views": {
      "playwright-locator-toolkit-container": [
        {
          "type": "webview",
          "id": "playwright-locator-toolkit-sidebar",
          "name": "Playwright Live Playground (Debug Assistant)"
        }
      ]
    },
    "configuration": {
      "title": "Playwright Live Playground (Debug Assistant)",
      "properties": {
        "playwright-locator-toolkit.browserPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Optional: Custom path to Google Chrome/Chromium executable. If empty, the extension will attempt to auto-detect Google Chrome."
        },
        "playwright-locator-toolkit.debuggingPort": {
          "type": "integer",
          "default": 9222,
          "minimum": 1024,
          "maximum": 65535,
          "description": "The port to use for Chrome remote debugging."
        },
        "playwright-locator-toolkit.enableBetaFeatures": {
          "type": "boolean",
          "default": false,
          "description": "Enable advanced beta features: Stability testing, action simulation, POM/SDK exports, etc."
        },
        "playwright-locator-toolkit.cleanBrowserProfile": {
          "type": "boolean",
          "default": false,
          "description": "If true, deletes the browser's temporary user profile directory on exit. If false, persists it for fast launch."
        },
        "playwright-locator-toolkit.tempDir": {
          "type": "string",
          "default": "",
          "description": "Optional: Folder path where temporary playground scripts are created. Can be an absolute path or relative to the workspace root."
        }
      }
    },
    "commands": [
      {
        "command": "playwright-locator-toolkit.openSidebar",
        "title": "Open Playwright Live Playground",
        "category": "Playwright Live Playground"
      },
      {
        "command": "playwright-locator-toolkit.restart",
        "title": "Restart Extension",
        "category": "Playwright Live Playground"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node build.js",
    "watch": "node build.js --watch",
    "build": "npm run compile",
    "package": "vsce package"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sudharsandhoni/PlaywrightLocatorToolkit.git"
  },
  "bugs": {
    "url": "https://github.com/Sudharsandhoni/PlaywrightLocatorToolkit/issues"
  },
  "homepage": "https://github.com/Sudharsandhoni/PlaywrightLocatorToolkit#readme",
  "dependencies": {
    "playwright-core": "^1.61.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.28.1",
    "playwright-locator-toolkit-engine": "file:../engine",
    "playwright-locator-toolkit-parser": "file:../locator-parser",
    "playwright-locator-toolkit-shared": "file:../shared"
  }
}
