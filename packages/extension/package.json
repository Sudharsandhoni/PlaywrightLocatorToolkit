{
  "name": "playwright-locator-lens",
  "displayName": "Playwright Locator Lens",
  "description": "Live Playwright Locator Validation & Analysis in VS Code",
  "version": "0.1.0",
  "publisher": "playwright-tools",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "playwright-locator-lens-container",
          "title": "Playwright Locator Lens",
          "icon": "$(eye)"
        }
      ]
    },
    "views": {
      "playwright-locator-lens-container": [
        {
          "type": "webview",
          "id": "playwright-locator-lens-sidebar",
          "name": "Playwright Locator Lens"
        }
      ]
    },
    "configuration": {
      "title": "Playwright Locator Lens",
      "properties": {
        "playwright-locator-lens.browserPath": {
          "type": "string",
          "default": "",
          "description": "Optional: Custom path to Google Chrome/Chromium executable. If empty, the extension will attempt to auto-detect Google Chrome."
        },
        "playwright-locator-lens.debuggingPort": {
          "type": "integer",
          "default": 9222,
          "description": "The port to use for Chrome remote debugging."
        },
        "playwright-locator-lens.enableBetaFeatures": {
          "type": "boolean",
          "default": false,
          "description": "Enable advanced beta features: Stability testing, action simulation, POM/SDK exports, etc."
        },
        "playwright-locator-lens.cleanBrowserProfile": {
          "type": "boolean",
          "default": false,
          "description": "If true, deletes the browser's temporary user profile directory on exit. If false, persists it for fast launch."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node build.js",
    "watch": "node build.js --watch",
    "build": "npm run compile",
    "package": "vsce package"
  },
  "dependencies": {
    "playwright-core": "^1.40.0",
    "playwright-locator-lens-engine": "file:../engine",
    "playwright-locator-lens-parser": "file:../locator-parser",
    "playwright-locator-lens-shared": "file:../shared"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.28.1"
  }
}
