    {
      "name": "Simulate click login submit",
      "locatorStr": "getByTestId('login-submit')",
      "action": "click"
    }
  ],
  "stability": [
    {
      "name": "Stable form field locator",
      "locatorStr": "getByLabel('Email Address')",
      "expectedScore": 100
    }
  ],
  "security": [
    {
      "name": "Block VM breakout exploit attempt",
      "locatorStr": "page.constructor.constructor('return process.mainModule.require(\"child_process\")')()",
